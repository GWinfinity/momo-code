{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "momocode",
  "version": "0.1.0",
  "description": "AI-powered coding agent -- momo Code",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd packages/opencode && npm run dev",
    "dev:web": "cd packages/app && npm run dev",
    "typecheck": "cd packages/opencode && npm run typecheck",
    "lint": "cd packages/opencode && npm run lint",
    "test": "cd packages/opencode && npm test",
    "build": "cd packages/opencode && npm run build",
    "postinstall": "cd packages/opencode && npm install",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/momo-team/momo-code"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}
