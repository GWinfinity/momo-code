#!/usr/bin/env bash
set -euo pipefail
APP=momo

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
${APP} Code Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 1.0.0)
    -b, --binary <path>     Install from a local binary instead of downloading
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)

Examples:
    curl -fsSL https://momozi.cc/install | bash
    curl -fsSL https://momozi.cc/install | bash -s -- --version 1.0.0
    ./install --binary /path/to/momo
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            if [[ -n "${2:-}" ]]; then
                requested_version="$2"
                shift 2
            else
                echo -e "${RED}Error: --version requires a version argument${NC}"
                exit 1
            fi
            ;;
        -b|--binary)
            if [[ -n "${2:-}" ]]; then
                binary_path="$2"
                shift 2
            else
                echo -e "${RED}Error: --binary requires a path argument${NC}"
                exit 1
            fi
            ;;
        --no-modify-path)
            no_modify_path=true
            shift
            ;;
        *)
            echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
            shift
            ;;
    esac
done

INSTALL_DIR=$HOME/.momo/bin
mkdir -p "$INSTALL_DIR"

# If --binary is provided, skip all download/detection logic
if [ -n "$binary_path" ]; then
    if [ ! -f "$binary_path" ]; then
        echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"
        exit 1
    fi
    specific_version="local"
else
    raw_os=$(uname -s)
    os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
    case "$raw_os" in
      Darwin*) os="darwin" ;;
      Linux*) os="linux" ;;
      MINGW*|MSYS*|CYGWIN*) os="win32" ;;
    esac

    arch=$(uname -m)
    if [[ "$arch" == "aarch64" ]]; then
      arch="arm64"
    fi
    if [[ "$arch" == "x86_64" ]]; then
      arch="x64"
    fi

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
      rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
      if [ "$rosetta_flag" = "1" ]; then
        arch="arm64"
      fi
    fi

    combo="$os-$arch"
    case "$combo" in
      linux-x64|linux-arm64|darwin-x64|darwin-arm64|win32-x64)
        ;;
      *)
        echo -e "${RED}Unsupported OS/Arch: $os/$arch${NC}"
        exit 1
        ;;
    esac

    archive_ext=".zip"
    if [ "$os" = "linux" ]; then
      archive_ext=".tar.gz"
    fi

    is_musl=false
    if [ "$os" = "linux" ]; then
      if [ -f /etc/alpine-release ]; then
        is_musl=true
      fi

      if command -v ldd >/dev/null 2>&1; then
        if ldd --version 2>&1 | grep -qi musl; then
          is_musl=true
        fi
      fi
    fi

    needs_baseline=false
    if [ "$arch" = "x64" ]; then
      if [ "$os" = "linux" ]; then
        if ! grep -qwi avx2 /proc/cpuinfo 2>/dev/null; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "darwin" ]; then
        avx2=$(sysctl -n hw.optional.avx2_0 2>/dev/null || echo 0)
        if [ "$avx2" != "1" ]; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "win32" ]; then
        ps="(Add-Type -MemberDefinition \"[DllImport(\\\"kernel32.dll\\\")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);\" -Name Kernel32 -Namespace Win32 -PassThru)::IsProcessorFeaturePresent(40)"
        out=""
        if command -v powershell.exe >/dev/null 2>&1; then
          out=$(powershell.exe -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        elif command -v pwsh >/dev/null 2>&1; then
          out=$(pwsh -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        fi
        out=$(echo "$out" | tr -d '\r' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
        if [ "$out" != "true" ] && [ "$out" != "1" ]; then
          needs_baseline=true
        fi
      fi
    fi

    target="$os-$arch"
    if [ "$needs_baseline" = "true" ]; then
      target="$target-baseline"
    fi
    if [ "$is_musl" = "true" ]; then
      target="$target-musl"
    fi

    filename="$APP-$target$archive_ext"

    if [ "$os" = "linux" ]; then
        if ! command -v tar >/dev/null 2>&1; then
             echo -e "${RED}Error: 'tar' is required but not installed.${NC}"
             exit 1
        fi
    else
        if ! command -v unzip >/dev/null 2>&1; then
            echo -e "${RED}Error: 'unzip' is required but not installed.${NC}"
            exit 1
        fi
    fi

    if [ -z "$requested_version" ]; then
        url="https://github.com/momozi1996/momo-code/releases/latest/download/$filename"
        specific_version=$(curl -s https://api.github.com/repos/momozi1996/momo-code/releases/latest | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')

        if [[ $? -ne 0 || -z "$specific_version" ]]; then
            specific_version="1.0.0"
        fi
    else
        requested_version="${requested_version#v}"
        url="https://github.com/momozi1996/momo-code/releases/download/v${requested_version}/$filename"
        specific_version=$requested_version
    fi
fi

print_message() {
    local level=$1
    local message=$2
    local color=""

    case $level in
        info) color="${NC}" ;;
        warning) color="${NC}" ;;
        error) color="${RED}" ;;
    esac

    echo -e "${color}${message}${NC}"
}

check_version() {
    if command -v momo >/dev/null 2>&1; then
        installed_version=$(momo --version 2>/dev/null || echo "")

        if [[ "$installed_version" != "$specific_version" ]]; then
            print_message info "${MUTED}Installed version: ${NC}$installed_version."
        else
            print_message info "${MUTED}Version ${NC}$specific_version${MUTED} already installed"
            exit 0
        fi
    fi
}

download_with_progress() {
    local url="$1"
    local output="$2"
    # --max-time 60: fail fast if download hangs, triggers source fallback
    curl --max-time 60 -# -L -o "$output" "$url" 2>&1
}

download_and_install() {
    print_message info "\n${MUTED}Installing ${NC}${APP} ${MUTED}version: ${NC}$specific_version"
    local tmp_dir="${TMPDIR:-/tmp}/${APP}_install_$$"
    mkdir -p "$tmp_dir"

    # Check if release asset exists
    local http_status=$(curl -sI -o /dev/null -w "%{http_code}" "$url")
    if [ "$http_status" = "404" ] || [ "$http_status" = "302" ]; then
        # Follow redirect and check final status
        local final_status=$(curl -sL -I -o /dev/null -w "%{http_code}" "$url")
        if [ "$final_status" = "404" ]; then
            print_message info "${MUTED}Release binary not available, installing from source...${NC}"
            install_from_source
            return 0
        fi
    fi

    if ! download_with_progress "$url" "$tmp_dir/$filename"; then
        print_message info "${MUTED}Download failed, falling back to source install...${NC}"
        install_from_source
        return 0
    fi

    # Verify downloaded file is not empty
    if [ ! -s "$tmp_dir/$filename" ]; then
        print_message info "${MUTED}Downloaded file is empty, falling back to source install...${NC}"
        install_from_source
        return 0
    fi

    if [ "$os" = "linux" ]; then
        tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"
    else
        unzip -q "$tmp_dir/$filename" -d "$tmp_dir"
    fi

    mv "$tmp_dir/momo" "$INSTALL_DIR"
    chmod 755 "${INSTALL_DIR}/momo"
    rm -rf "$tmp_dir"
}

install_from_source() {
    print_message info "${MUTED}Cloning from GitHub...${NC}"
    local src_dir="$HOME/.momo/lib/momo-code"
    rm -rf "$src_dir"
    mkdir -p "$src_dir"

    if ! git clone --depth 1 --branch "v${specific_version}" https://github.com/momozi1996/momo-code.git "$src_dir" 2>/dev/null; then
        print_message info "${MUTED}Tag not found, cloning main branch...${NC}"
        git clone --depth 1 https://github.com/momozi1996/momo-code.git "$src_dir"
    fi

    print_message info "${MUTED}Installing dependencies (this may take a minute)...${NC}"
    cd "$src_dir/packages/opencode"


    # Install ALL dependencies (including devDependencies) — build needs TypeScript
       # Install ALL dependencies (including devDependencies) — build needs TypeScript
    print_message info "${MUTED}Installing dependencies (this may take a minute)...${NC}"
    if ! npm install >> /tmp/momo-install.log 2>&1; then
        print_message error "${RED}Failed to install dependencies. Last 20 lines:${NC}"
        tail -20 /tmp/momo-install.log
        print_message info "${MUTED}Full log: /tmp/momo-install.log${NC}"
        print_message info "${MUTED}Install Node.js >= 20 from https://nodejs.org${NC}"
        exit 1
    fi

    # Build: compiles TypeScript + fixes ESM imports automatically
    print_message info "${MUTED}Building from source...${NC}"
    if ! npm run build >> /tmp/momo-install.log 2>&1; then
        print_message error "${RED}Build failed. Last 20 lines:${NC}"
        tail -20 /tmp/momo-install.log
        print_message info "${MUTED}Full log: /tmp/momo-install.log${NC}"
        exit 1
    fi

    # Create wrapper script
    cat > "$INSTALL_DIR/momo" << 'WRAPPER'
#!/usr/bin/env bash
export MOMO_HOME="${MOMO_HOME:-$HOME/.momo}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
node "$HOME/.momo/lib/momo-code/packages/opencode/bin/momo" "$@"
WRAPPER
    chmod +x "$INSTALL_DIR/momo"

    print_message info "${MUTED}Installed from source to ${NC}$src_dir${NC}"
}

install_from_binary() {
    print_message info "\n${MUTED}Installing ${NC}${APP} ${MUTED}from: ${NC}$binary_path"
    cp "$binary_path" "${INSTALL_DIR}/momo"
    chmod 755 "${INSTALL_DIR}/momo"
}

# ===== MAIN =====

if [ -n "$binary_path" ]; then
    install_from_binary
else
    check_version
    download_and_install
fi

# Add to PATH if not already present
if [ "$no_modify_path" != true ]; then
    shell=$(basename "$SHELL")
    case "$shell" in
        zsh)
            config_file="$HOME/.zshrc"
            ;;
        bash)
            config_file="$HOME/.bashrc"
            ;;
        fish)
            config_file="$HOME/.config/fish/config.fish"
            ;;
        *)
            config_file=""
            ;;
    esac

    if [ -n "$config_file" ] && [ -f "$config_file" ]; then
        if ! grep -q "$INSTALL_DIR" "$config_file" 2>/dev/null; then
            echo "" >> "$config_file"
            echo "# momo Code CLI" >> "$config_file"
            case "$shell" in
                fish)
                    echo "set -gx PATH $INSTALL_DIR \$PATH" >> "$config_file"
                    ;;
                *)
                    echo "export PATH=\"$INSTALL_DIR:\$PATH\"" >> "$config_file"
                    ;;
            esac
            print_message info "${MUTED}Added $INSTALL_DIR to PATH in $config_file${NC}"
            print_message info "${MUTED}Run 'source $config_file' to apply changes${NC}"
        fi
    fi
fi

print_message info "\n${MUTED}${APP} Code ${NC}v${specific_version} ${MUTED}installed to ${NC}${INSTALL_DIR}/${APP}"
print_message info "${MUTED}Run '${APP} --help' to get started${NC}\n"
